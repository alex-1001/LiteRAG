# Local Ollama (default)
LLM_PROVIDER=ollama
LLM_MODEL=gemma4

# To use OpenRouter instead, replace the two values above and provide a key:
# LLM_PROVIDER=openrouter
# LLM_MODEL=openai/gpt-4o-mini
# LLM_API_KEY=your_key

# Optional: defaults to the selected provider's standard endpoint.
# LLM_BASE_URL=http://localhost:11434/v1

EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# Optional: HuggingFace AutoTokenizer for chunking (defaults to EMBED_MODEL_NAME)
# TOKENIZER_NAME=

# Root folder for document ingest. /ingest source_path values must stay inside this directory.
DATA_DIR=data/raw
STORAGE_DIR=storage

# Maximum number of chunks to retrieve.
TOP_K=5

# Chunking units are tokens according to the configured tokenizer.
CHUNK_SIZE=200
CHUNK_OVERLAP=50
